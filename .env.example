# ─────────────────────────────────────────────────────────────
#  Web3 LeadForge — environment configuration
#  Copy this file to `.env` and fill in your own keys.
#  NEVER commit `.env` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# ── Provider switches ────────────────────────────────────────
# The app is FREE by default: DuckDuckGo search + Google Gemini.
#   SEARCH_PROVIDER   : free  (DuckDuckGo, no key)  |  grok  (paid xAI live web+X)
#   ANALYZER_PROVIDER : gemini (free)  |  claude (paid)  |  grok (paid)
# To switch back to xAI later, set SEARCH_PROVIDER=grok (and add credits),
# and/or ANALYZER_PROVIDER=claude or grok.
SEARCH_PROVIDER=free
ANALYZER_PROVIDER=gemini

# ── Free stack keys ──────────────────────────────────────────
# Google Gemini — FREE key, no credit card: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Paid stack keys (optional) ───────────────────────────────
# xAI Grok — https://console.x.ai  (live web + X research)
XAI_API_KEY=
GROK_MODEL=grok-4

# Anthropic Claude — https://console.anthropic.com  (sharper scoring)
#   claude-sonnet-4-6  → recommended for batch scoring (cost/quality balance)
#   claude-opus-4-8    → highest judgment quality (pricier)
#   claude-haiku-4-5   → cheapest / fastest, lighter reasoning
ANTHROPIC_API_KEY=
ANALYZER_MODEL=claude-sonnet-4-6

# Reasoning effort for the Claude analyzer: low | medium | high
# (ignored automatically for haiku, which doesn't support effort)
ANALYZER_EFFORT=low
